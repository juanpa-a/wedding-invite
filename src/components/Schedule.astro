---
import { getEventData, type ScheduleContent, type ExpandableDetail } from "../data/eventData";
interface Props { schedule?: ScheduleContent }
const { schedule: scheduleProp } = Astro.props;
const { schedule: scheduleDefault } = getEventData();
const schedule = scheduleProp ?? scheduleDefault;
const events = schedule.events ?? [];
---

<section
    style="
        background-color: var(--color-primary);
        color: var(--color-secondary);
    "
>
    <div class="mx-auto w-full max-w-6xl px-4 py-24 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
            <p
                class="text-sm uppercase tracking-[0.35em]"
                style="color: var(--color-muted);"
            >
                {schedule.eyebrow}
            </p>
            <h2
                class="mt-4 text-4xl font-semibold tracking-tight sm:text-5xl lg:text-6xl"
                style="color: var(--color-secondary);"
            >
                {schedule.title}
            </h2>
            <p
                class="mt-6 text-lg"
                style="color: var(--color-secondary); opacity: 0.8;"
            >
                {schedule.description}
            </p>
        </div>

        <div class="mt-16 flex flex-col">
            {
                events.map((event) => (
                    <article
                        class="sticky top-0 z-10 border-t border-dashed py-12 backdrop-blur"
                        style="
                            border-color: var(--color-muted);
                            background: color-mix(in srgb, var(--color-primary) 95%, transparent);
                        "
                    >
                        <div class="grid gap-10 lg:grid-cols-5 lg:items-start lg:gap-0">
                            <span
                                class="text-5xl font-bold tracking-tight sm:text-6xl lg:text-7xl"
                                style="color: var(--color-secondary);"
                            >
                                {event.number}
                            </span>
                            <div
                                class="flex flex-col gap-10 lg:col-span-4 lg:pl-12 lg:border-l lg:border-dashed"
                                style="border-color: var(--color-muted);"
                            >
                                <div class="space-y-4">
                                    <p
                                        class="text-xs uppercase tracking-[0.35em]"
                                        style="color: var(--color-secondary); opacity: 0.6;"
                                    >
                                        {event.label}
                                    </p>
                                    <h3
                                        class="text-4xl font-semibold tracking-tight sm:text-5xl lg:text-6xl"
                                        style="color: var(--color-secondary);"
                                    >
                                        {event.title}
                                    </h3>
                                </div>
                                <p
                                    class="text-base sm:text-lg lg:text-xl max-w-2xl"
                                    style="color: var(--color-secondary); opacity: 0.9;"
                                >
                                    {event.description}
                                </p>
                                <ul
                                    class="space-y-3 text-sm sm:text-base"
                                    style="color: var(--color-secondary); opacity: 0.8;"
                                >
                                    {event.details.map((detail) =>
                                        typeof detail === "string" ? (
                                            <li class="flex items-start gap-3 leading-relaxed">
                                                <span
                                                    class="mt-1 inline-block h-1.5 w-1.5 rounded-full"
                                                    style="background: var(--color-accent); opacity: 0.5;"
                                                />
                                                <span>{detail}</span>
                                            </li>
                                        ) : (
                                            <li class="detail-accordion">
                                                <details>
                                                    <summary class="flex items-start gap-3 leading-relaxed cursor-pointer list-none">
                                                        <span
                                                            class="mt-1 inline-block h-1.5 w-1.5 rounded-full shrink-0"
                                                            style="background: var(--color-accent); opacity: 0.5;"
                                                        />
                                                        <span class="flex-1">{(detail as ExpandableDetail).text}</span>
                                                        <span class="detail-chevron mt-1 shrink-0" aria-hidden="true">
                                                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                                                                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                                            </svg>
                                                        </span>
                                                    </summary>
                                                    <div class="detail-expandable-content pl-[1.125rem] mt-4 space-y-4">
                                                        {(detail as ExpandableDetail).sections.map((section) => (
                                                            <div>
                                                                <p class="font-semibold text-sm mb-2" style="color: var(--color-secondary);">
                                                                    {section.title}
                                                                </p>
                                                                <ul class="space-y-1.5">
                                                                    {section.items.map((item) => (
                                                                        <li class="flex items-start gap-2 text-sm leading-relaxed">
                                                                            <span
                                                                                class="mt-1.5 inline-block h-1 w-1 rounded-full shrink-0"
                                                                                style="background: var(--color-accent); opacity: 0.35;"
                                                                            />
                                                                            <span>{item}</span>
                                                                        </li>
                                                                    ))}
                                                                </ul>
                                                            </div>
                                                        ))}
                                                    </div>
                                                </details>
                                            </li>
                                        )
                                    )}
                                </ul>
                            </div>
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>

<style>
    .detail-accordion summary::-webkit-details-marker {
        display: none;
    }

    .detail-chevron {
        transition: transform 0.25s ease;
        opacity: 0.5;
    }

    details[open] > summary .detail-chevron {
        transform: rotate(180deg);
    }

    .detail-expandable-content {
        animation: accordion-open 0.25s ease;
    }

    @keyframes accordion-open {
        from {
            opacity: 0;
            transform: translateY(-4px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

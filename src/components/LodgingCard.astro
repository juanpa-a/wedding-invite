---
import type { LodgingPlace } from "../data/eventData";

interface Props {
    place: LodgingPlace;
}

const { place } = Astro.props;
---

<article
    class="rounded-3xl border p-6 sm:p-8"
    style={
        place.highlight
            ? `border-color: var(--color-accent); border-width: 2px;`
            : `border-color: color-mix(in srgb, var(--color-primary) 20%, transparent);`
    }
>
    <div class="mb-4 flex flex-wrap items-center gap-2">
        {place.badge && (
            <span
                class="rounded-full px-3 py-1 text-xs uppercase tracking-[0.2em]"
                style={
                    place.highlight
                        ? `background: var(--color-accent); color: var(--color-background);`
                        : `background: color-mix(in srgb, var(--color-primary) 10%, transparent); color: var(--color-primary);`
                }
            >
                {place.badge}
            </span>
        )}
        <span
            class="rounded-full border px-3 py-1 text-xs"
            style="border-color: color-mix(in srgb, var(--color-primary) 20%, transparent); color: var(--color-primary); opacity: 0.7;"
        >
            {place.priceRange}
        </span>
    </div>

    <h3
        class="text-xl font-semibold font-(--font-display)"
        style="color: var(--color-primary);"
    >
        {place.name}
    </h3>

    <p
        class="mt-2 text-base leading-relaxed"
        style="color: var(--color-primary); opacity: 0.8;"
    >
        {place.description}
    </p>

    {place.note && (
        <p
            class="mt-3 text-sm italic"
            style="color: var(--color-accent); opacity: 0.9;"
        >
            {place.note}
        </p>
    )}

    <div class="mt-4 flex flex-wrap gap-4">
        {place.website && (
            <a
                href={place.website}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm underline underline-offset-4"
                style="color: var(--color-primary); opacity: 0.6;"
            >
                Sitio web
            </a>
        )}
        {place.phone && (
            <a
                href={`tel:${place.phone}`}
                class="inline-flex items-center gap-1.5 text-sm underline underline-offset-4"
                style="color: var(--color-primary); opacity: 0.6;"
            >
                {place.phone}
            </a>
        )}
    </div>
</article>

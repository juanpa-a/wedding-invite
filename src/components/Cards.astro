---
import Card from "./Card.astro";
import { getEventData, type CardContent } from "../data/eventData";
interface Props { cards?: CardContent[] }
const { cards: cardsProp } = Astro.props;
const { cards: cardsDefault = [] } = getEventData();
const cards = cardsProp ?? cardsDefault;
---

<section class="max-w-4xl mx-auto my-16 px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {
            cards.map((card) => (
                <a
                    href={card.href}
                    class="group block focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
                >
                    <Card
                        image={card.image}
                        imageAlt={card.imageAlt}
                        title={card.title}
                        description={card.description}
                    />
                </a>
            ))
        }
    </div>
</section>

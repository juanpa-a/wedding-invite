---
import { getEventData, type LodgingContent } from "../data/eventData";
import LodgingCard from "./LodgingCard.astro";
interface Props { lodging?: LodgingContent }
const { lodging: lodgingProp } = Astro.props;
const { lodging: lodgingDefault } = getEventData();
const lodging = lodgingProp ?? lodgingDefault;
---

<section
    class="py-24 px-6"
    style="background-color: var(--color-background); color: var(--color-primary);"
>
    <div class="mx-auto w-full max-w-6xl">
        <header class="mb-12 max-w-3xl">
            <h2
                class="text-4xl font-semibold tracking-tight font-(--font-display) sm:text-5xl lg:text-6xl"
                style="color: var(--color-primary);"
            >
                {lodging.title}
            </h2>
            <p
                class="mt-6 text-lg leading-relaxed"
                style="color: var(--color-primary); opacity: 0.75;"
            >
                {lodging.description}
            </p>
        </header>

        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {lodging.places.map((place) => (
                <LodgingCard place={place} />
            ))}
        </div>
    </div>
</section>

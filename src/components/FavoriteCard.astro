---
import type { FavoritePlace } from "../data/eventData";

interface Props {
    place: FavoritePlace;
}

const { place } = Astro.props;
const isVale = place.favoriteDe === "vale";
const badgeLabel = isVale ? "El favorito de Vale" : "El favorito de Juanpa";
---

<article
    class="border-t border-dashed py-6"
    style="border-color: color-mix(in srgb, var(--color-primary) 25%, transparent);"
>
    <p
        class="text-xs uppercase tracking-[0.35em]"
        style="color: var(--color-primary); opacity: 0.5;"
    >
        {badgeLabel}
    </p>

    <h3
        class="mt-2 text-xl font-semibold font-(--font-display)"
        style="color: var(--color-primary);"
    >
        {place.name}
    </h3>

    <p
        class="mt-2 text-base leading-relaxed"
        style="color: var(--color-primary); opacity: 0.8;"
    >
        {place.description}
    </p>

    {place.recommendedDish && (
        <p
            class="mt-2 text-sm italic"
            style="color: var(--color-primary); opacity: 0.65;"
        >
            Pedir: {place.recommendedDish}
        </p>
    )}

    {place.instagram && (
        <a
            href={place.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-3 inline-flex items-center gap-1.5 text-sm underline underline-offset-4"
            style="color: var(--color-primary); opacity: 0.6;"
        >
            Ver en Instagram
        </a>
    )}
</article>

---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import Story from "../../components/Story.astro";
import Schedule from "../../components/Schedule.astro";
import Cards from "../../components/Cards.astro";
import Gallery from "../../components/Gallery.astro";
import Favorites from "../../components/Favorites.astro";
import Lodging from "../../components/Lodging.astro";
import Count from "../../components/Count.astro";
import { getEventData } from "../../data/eventData";

const data = getEventData("en");
---

<Layout lang="en" title="Vale & Juanpa — Our Wedding">
    <Hero hero={data.hero} />
    <Story story={data.story} />
    <Schedule schedule={data.schedule} />
    <Cards cards={data.cards} />
    <Gallery gallery={data.gallery} />
    <Favorites favorites={data.favorites} />
    <Lodging lodging={data.lodging} />
    <Count countdown={data.countdown} />
</Layout>
